<?xml version="1.0" encoding="UTF-8"?>
<launch>

      <!-- Expose le dossier models/ à Gazebo pour résoudre model://map_plane -->
      <set_env name="GZ_SIM_RESOURCE_PATH"
            value="$(find-pkg-share curt_mini)/models"/>

      <!-- Gazebo -->
      <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
            <arg name="gz_args" value="-s -r -v 1 $(find-pkg-share curt_mini)/models/curt_mini/worlds/world.sdf"/>
      </include>


        <!-- Navigation stack -->
      <timer period="6.0">
            <include file="$(find-pkg-share navigation_pkg)/launch/global_launch.py"/>
      </timer>

      <timer period="2.0">
      <node
            pkg="ros_gz_sim"
            exec="create"     
            output="screen"
            args="-topic robot_description -x 3.849 -y 13.486 -z 0.65 -yaw 0.0 -name curt_mini"/>
      </timer>

      <node pkg="ros_gz_bridge"
            exec="parameter_bridge"
            output="screen"
            args="--ros-args -p config_file:=$(find-pkg-share curt_mini)/config/gz_bridge.yaml"/>

      <!-- Robot State Publisher -->
      <node pkg="robot_state_publisher"
            exec="robot_state_publisher"
            output="screen">
            <param name="robot_description"
                  value="$(command 'xacro $(find-pkg-share curt_mini)/models/curt_mini/robot.urdf.xacro simulation:=True')"/>
      </node>

      <!-- Controller manager -->
      <timer period="8.0">
      <node pkg="controller_manager"
            exec="spawner"
            output="screen"
            args="--param-file $(find-pkg-share curt_mini)/config/ros2_control_simulation.yaml
                  joint_state_broadcaster"/>
      </timer>

      <timer period="10.0">
      <node pkg="controller_manager"
      exec="spawner"
      output="screen"
      args="--param-file $(find-pkg-share curt_mini)/config/ros2_control_simulation.yaml
            --controller-ros-args '--ros-args --remap diff_drive_controller/odom:=/odometry/wheel --remap diff_drive_controller/cmd_vel:=/cmd_vel'
            diff_drive_controller"/>
      </timer>

      <!-- RViz -->
      <timer period="10.0">
      <node pkg="rviz2"
            exec="rviz2"
            name="rviz2"
            output="screen"
            args="-d $(find-pkg-share curt_mini)/bringup/curt_mini.rviz"/>
      </timer>

</launch>
